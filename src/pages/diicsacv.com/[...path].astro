---
import { access, readdir, readFile } from 'node:fs/promises';
import { join } from 'node:path';

export async function getStaticPaths() {
  const mirrorRoot = join(process.cwd(), 'diicsacv.com');
  const entries = await readdir(mirrorRoot, { withFileTypes: true });
  const pageDirs = [];

  for (const entry of entries) {
    if (!entry.isDirectory()) continue;

    try {
      await access(join(mirrorRoot, entry.name, 'index.html'));
      pageDirs.push(entry.name);
    } catch {
      // Asset directories are copied to public but do not become Astro routes.
    }
  }

  return pageDirs.map((entry) => ({
      params: { path: entry },
      props: { slug: entry },
    }));
}

const mirrorRoot = join(process.cwd(), 'diicsacv.com');
const html = await readFile(join(mirrorRoot, Astro.props.slug, 'index.html'), 'utf8');
const noindexHtml = html.includes("name='robots'") || html.includes('name="robots"')
  ? html.replace(/<meta\s+name=['"]robots['"][^>]*>/i, '<meta name="robots" content="noindex, follow">')
  : html.replace(/<head>/i, '<head><meta name="robots" content="noindex, follow">');

return new Response(noindexHtml, {
  headers: {
    'content-type': 'text/html; charset=utf-8',
  },
});
---
