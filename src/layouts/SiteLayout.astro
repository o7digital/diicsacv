---
import { asset, navItems, navItemsEn } from '../data/site.js';
import OliviaChat from '../components/OliviaChat.astro';

const {
  title = 'DIICSA // Constructora mexicana',
  description = 'Constructora mexicana especializada en diseno, construccion y mantenimiento integral.',
  lang = 'es',
} = Astro.props;

const isEnglish = lang === 'en';
const navigation = isEnglish ? navItemsEn : navItems;
const currentPath = Astro.url.pathname;
const spanishHref = isEnglish ? currentPath.replace(/^\/en(?=\/|$)/, '') || '/' : currentPath;
const englishHref = isEnglish ? currentPath : `/en${currentPath === '/' ? '/' : currentPath}`;
const scheduleLabel = isEnglish ? 'Monday to Friday, 8 to 17h' : 'Lunes a Viernes, 8 a 17h';
const privacyLabel = isEnglish ? 'Privacy Notice' : 'Aviso de Privacidad';
const footerText = isEnglish
  ? 'DIICSA // Mexican Construction Company | All rights reserved'
  : 'DIICSA // Constructora Mexicana | Todos los derechos reservados';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-RWZ9WLNQL9"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-RWZ9WLNQL9');
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="topbar">
        <a href="tel:525526020324">+52 55 2602 0324</a>
        <span>{scheduleLabel}</span>
        <nav aria-label="Social">
          <a href="https://wa.me/525526020324">WhatsApp</a>
          <a href="https://www.linkedin.com/company/diicsacv">LinkedIn</a>
        </nav>
      </div>
      <div class="nav-wrap">
        <nav class="language-nav" aria-label="Language">
          <a class:list={[isEnglish && 'is-active']} href={englishHref}>EN <span aria-hidden="true">⌄</span></a>
          <a class:list={[!isEnglish && 'is-active']} href={spanishHref}>ES</a>
        </nav>
        <a class="brand" href={isEnglish ? '/en/' : '/'}>
          <img src={asset('2022/10/logo_diicsa.jpg')} alt="DIICSA" />
        </a>
        <nav class="main-nav" aria-label="Principal">
          {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </div>
    </header>

    <slot />
    <OliviaChat />

    <footer class="site-footer">
      <div class="container footer-grid">
        <img src={asset('2022/10/logo_diicsa.jpg')} alt="DIICSA" />
        <p>{footerText}</p>
        <a href={isEnglish ? '/en/aviso-privacidad/' : '/aviso-privacidad/'}>{privacyLabel}</a>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --blue: #00214e;
    --blue-soft: #314e77;
    --pink: #d3316b;
    --ink: #263241;
    --muted: #6d7480;
    --line: #d9dee6;
    --surface: #f6f7f9;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: Roboto, Arial, sans-serif;
    color: var(--ink);
    background: #fff;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .container {
    width: min(1180px, calc(100% - 48px));
    margin: 0 auto;
  }

  .topbar {
    min-height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
    color: #5f6670;
    font-size: 16px;
    background: #fff;
  }

  .topbar nav {
    display: flex;
    gap: 10px;
    color: var(--blue);
    font-weight: 700;
  }

  .language-nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    min-width: 42px;
    color: #fff;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .language-nav a {
    opacity: 0.72;
  }

  .language-nav a.is-active {
    opacity: 1;
    text-decoration: none;
  }

  .language-nav span {
    font-size: 18px;
  }

  .nav-wrap {
    min-height: 126px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(28px, 6vw, 140px);
    padding: 16px 24px;
    background: rgba(0, 33, 78, 0.86);
    color: #fff;
  }

  .brand img {
    width: 124px;
    height: 110px;
    object-fit: contain;
    background: #fff;
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: clamp(18px, 3vw, 48px);
    font-size: 17px;
    font-weight: 700;
    text-transform: uppercase;
  }

  .main-nav a:first-child {
    color: #c5c5c5;
    border-bottom: 4px solid #fff;
    padding-bottom: 18px;
  }

  .page-hero {
    padding: clamp(70px, 9vw, 130px) 0;
    background:
      linear-gradient(rgba(0, 33, 78, 0.62), rgba(0, 33, 78, 0.42)),
      var(--hero-image);
    background-position: center;
    background-size: cover;
    color: #fff;
  }

  .page-hero .eyebrow {
    margin: 0 0 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .page-hero h1 {
    max-width: 850px;
    margin: 0;
    font-size: clamp(44px, 7vw, 92px);
    line-height: 1;
  }

  .section {
    padding: 72px 0;
  }

  .section-muted {
    background: var(--surface);
  }

  h2 {
    margin: 0 0 28px;
    color: #777;
    font-size: clamp(32px, 3.2vw, 48px);
    line-height: 1.1;
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.72fr);
    gap: 48px;
    align-items: start;
  }

  .prose {
    color: var(--muted);
    font-size: 20px;
    line-height: 1.75;
  }

  .prose p {
    margin: 0 0 22px;
  }

  .feature-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .button {
    display: inline-flex;
    margin-top: 18px;
    padding: 13px 18px;
    background: var(--blue);
    color: #fff;
    font-weight: 700;
    text-transform: uppercase;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  .card {
    border: 1px solid var(--line);
    background: #fff;
  }

  .card img {
    width: 100%;
    aspect-ratio: 850 / 519;
    object-fit: cover;
  }

  .card-body {
    padding: 22px;
  }

  .card h3 {
    margin: 0 0 10px;
    color: var(--pink);
    font-size: 24px;
  }

  .card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.55;
  }

  .site-footer {
    padding: 34px 24px;
    background: var(--blue);
    color: #fff;
  }

  .footer-grid {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .footer-grid img {
    width: 82px;
    height: 73px;
    object-fit: contain;
    background: #fff;
  }

  @media (max-width: 900px) {
    .topbar,
    .nav-wrap,
    .main-nav,
    .footer-grid {
      flex-wrap: wrap;
    }

    .nav-wrap {
      gap: 20px;
    }

    .main-nav {
      justify-content: center;
      font-size: 14px;
    }

    .content-grid,
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
